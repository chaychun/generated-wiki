# Provider auto-selected by which key is set.
# Force one with LLM_PROVIDER=anthropic | openrouter (optional).
# If both keys present and no override → Anthropic wins.

# --- Anthropic (primary when key present) ---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- OpenRouter (fallback / temporary default) ---
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=google/gemini-3-flash-preview

# Optional override: anthropic | openrouter
# LLM_PROVIDER=openrouter

# Optional OpenRouter ranking headers
# OR_REFERER=http://localhost:3000
# OR_TITLE=generated-wiki
